{
  "name": "cypress-bookapp",
  "version": "1.0.0",
  "description": "Cypress tests for BookApp",
  "main": "index.js",
  "scripts": {
    "test": "cypress run",
    "cy:open": "cypress open",
    "cy:run:chrome": "cypress run --browser chrome",
    "cy:run:headed": "cypress run --headed",
    "test:mobile": "cypress open --config-file cypress.mobile.config.js",
    "test:laptop": "cypress open --config-file cypress.laptop.config.js",
    "test:mobile:run": "cypress run --config-file cypress.mobile.config.js --headed",
    "test:laptop:run": "cypress run --config-file cypress.laptop.config.js --headed"
  },
  "author": "Olga Zotova",
  "license": "ISC",
  "devDependencies": {
    "cypress": "^13.6.0"
  }
}



