{
  "name": "cypress-bookapp",
  "version": "1.0.0",
  "description": "Cypress tests for BookApp",
  "main": "index.js",
  "scripts": {
    "test": "cypress run",
    "cy:open": "cypress open",

    "mobile:chrome:headed": "cypress run --config-file cypress.mobile.config.js --browser chrome --headed",
    "mobile:chrome:headless": "cypress run --config-file cypress.mobile.config.js --browser chrome",
    "mobile:edge:headed": "cypress run --config-file cypress.mobile.config.js --browser edge --headed",
    "mobile:edge:headless": "cypress run --config-file cypress.mobile.config.js --browser edge",

    "laptop:chrome:headed": "cypress run --config-file cypress.laptop.config.js --browser chrome --headed",
    "laptop:chrome:headless": "cypress run --config-file cypress.laptop.config.js --browser chrome",
    "laptop:edge:headed": "cypress run --config-file cypress.laptop.config.js --browser edge --headed",
    "laptop:edge:headless": "cypress run --config-file cypress.laptop.config.js --browser edge"
  },
  "author": "Olga Zotova",
  "license": "ISC",
  "devDependencies": {
    "cypress": "^13.6.0"
  }
}




